# Node.js LTS used for runtime
NODE_LTS_VERSION=20.11.1

# Asterisk AMI
ASTERISK_HOST=10.2.5.10
ASTERISK_PORT=5038
AMI_USERNAME=asterisk_ws
AMI_SECRET=change_me
AMI_RECONNECT_DELAY_MS=5000

# Creatio
CREATIO_BASE_URL=https://crm.example.com
CREATIO_CONTACTS_ENDPOINT=/0/odata/Contact
CREATIO_AUTH_TYPE=basic
CREATIO_USERNAME=integration_user
CREATIO_PASSWORD=change_me
CREATIO_CARD_URL_TEMPLATE=https://crm.example.com/0/Nui/ViewModule.aspx#CardModuleV2/ContactPageV2/edit/{id}

# WebSocket
WS_PORT=8080
WS_PATH=/ws
WS_ALLOWED_ORIGINS=https://chrome-extension://<id>,https://operator.example.com

# HTTP healthcheck
HTTP_PORT=8081

# Logging
LOG_LEVEL=info
